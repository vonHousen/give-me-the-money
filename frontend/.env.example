# Receipt scan / analyze: base URL (no trailing slash). POST goes to {base}/analyze. Empty -> mock.
VITE_RECEIPT_SCAN_API_URL=http://127.0.0.1:8000

# Settlements: base URL (no trailing slash). Endpoints appended by code. Empty -> mock.
VITE_SETTLEMENT_API_URL=http://127.0.0.1:8000


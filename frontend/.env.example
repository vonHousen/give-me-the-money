# Receipt scan: leave unset or empty to use the built-in mock (no network).
# When your backend is ready, set the full POST URL. The server must allow CORS from your dev origin.
# VITE_RECEIPT_SCAN_API_URL=http://127.0.0.1:8000/api/receipts/scan

# Settlements: base URL only (no trailing slash). POST goes to {base}/settlements. Empty → mock.
# VITE_SETTLEMENT_API_URL=http://127.0.0.1:8000

# Public app URL for QR codes and join links (no trailing slash). Production: https://gmtm.app
# VITE_PUBLIC_APP_URL=https://gmtm.app
